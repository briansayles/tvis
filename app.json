{
  "expo": {
    "name": "tvis",
    "description": "TourneyVision",
    "slug": "tvis",
    "privacy": "unlisted",
    "sdkVersion": "36.0.0",
    "version": "1.0.0",
    "orientation": "default",
    "primaryColor": "#cccccc",
    "icon": "./assets/icons/app-icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5b9f33"
    },
    "notification": {
      "icon": "./assets/icons/notification-icon.png",
      "color": "#000000"
    },
    "loading": {
      "icon": "./assets/icons/loading-icon.png",
      "hideExponentText": false
    },
    "packagerOpts": {
      "assetExts": [
        "ttf"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tourneyvision.tourneyvision",
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-3013833975597353~9684490974"
      }
    },
    "android": {
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-3013833975597353~9684490974"
      }
    },
    "githubUrl": "https://github.com/briansayles/tvis",
    "platforms": [
      "android",
      "ios"
    ]
  }
}
